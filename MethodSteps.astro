---
import { LANGS, type Lang } from '../config/site';
import { ROUTES } from '../i18n/routes';
import { ui } from '../i18n/ui';

interface Props {
  lang: Lang;
  alternates?: Partial<Record<Lang, string>>;
}
const { lang, alternates } = Astro.props;
const t = ui[lang];
const labels: Record<Lang, string> = { pt: 'PT', es: 'ES', en: 'EN' };
const names: Record<Lang, string> = { pt: 'Português', es: 'Español', en: 'English' };
const target = (l: Lang) => alternates?.[l] ?? ROUTES.home[l];
---

<nav class="lang" aria-label={t.a11y.lang}>
  {LANGS.map((l) => (
    <a
      href={target(l)}
      lang={l}
      hreflang={l}
      aria-label={names[l]}
      aria-current={l === lang ? 'true' : undefined}
      class:list={{ 'is-current': l === lang }}
    >
      {labels[l]}
    </a>
  ))}
</nav>

<style>
  .lang {
    display: inline-flex;
    align-items: center;
    border: 1px solid var(--line);
    border-radius: 999px;
    padding: 0.18rem;
    gap: 0.1rem;
  }
  .lang a {
    text-decoration: none;
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--muted);
    padding: 0.28rem 0.6rem;
    border-radius: 999px;
    border-bottom: none !important;
  }
  .lang a:hover {
    color: var(--ink);
  }
  .lang a.is-current {
    background: var(--ink);
    color: var(--white);
  }
</style>
