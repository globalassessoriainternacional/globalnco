---
import { BRAND_BY_LANG, waLink, LANGS, type Lang } from '../config/site';
import { ui } from '../i18n/ui';
import { route, SERVICE_FAMILIES, COUNTRY_KEYS } from '../i18n/routes';
import { content } from '../data';
import LangSwitcher from './LangSwitcher.astro';

interface Props { lang: Lang; alternates?: Partial<Record<Lang, string>> }
const { lang, alternates } = Astro.props;
const c = content[lang];
const brand = BRAND_BY_LANG[lang];
const current = Astro.url.pathname;
const isActive = (href: string) => (href === '/' ? current === href : current.startsWith(href));
---

<header class="hd">
  <div class="container hd__in">
    <a class="logo" href={route('home', lang)} aria-label="Global & Co.">
      <svg class="logo__mark" viewBox="0 0 48 48" aria-hidden="true" width="32" height="32">
        <path d="M24 3C14.6 3 7 10.6 7 20c0 11.9 14.1 23.4 16 24.8a1.6 1.6 0 0 0 2 0C26.9 43.4 41 31.9 41 20 41 10.6 33.4 3 24 3Z" fill="var(--gold)"/>
        <path d="M32.8 15.1c.9-.9 1.1-2.2.4-2.9-.7-.7-2-.5-2.9.4l-4 4-8.9-2.6a1 1 0 0 0-1 .3l-.9.9a1 1 0 0 0 .2 1.5l6.8 4.2-3.8 3.9-2.9-.4a.8.8 0 0 0-.7.2l-.6.7a.8.8 0 0 0 .2 1.3l3.4 1.9 1.9 3.4a.8.8 0 0 0 1.3.2l.6-.6a.8.8 0 0 0 .3-.8l-.4-2.9 3.9-3.8 4.2 6.8a1 1 0 0 0 1.5.2l.9-.9a1 1 0 0 0 .3-1l-2.6-8.9 3.9-4.1Z" fill="var(--ink)"/>
      </svg>
      <span class="logo__txt"><strong>Global&nbsp;&amp;&nbsp;Co.</strong><em>{brand.tagline}</em></span>
    </a>

    <nav class="nav" aria-label="Principal">
      <button class="nav__tgl" type="button" aria-expanded="false" aria-controls="nav-list" aria-label="Abrir menu">
        <span></span><span></span><span></span>
      </button>

      <ul id="nav-list" class="nav__list">
        <li class="has-sub">
          <button type="button" class="sub__btn" aria-expanded="false">{ui[lang].nav.countries}</button>
          <div class="sub sub--countries">
            <div class="sub__grid">
              {COUNTRY_KEYS.map((k) => {
                const key = k.replace('country:', '');
                const co = c.countries[key];
                return (
                  <a class="sub__card" href={route(k, lang)}>
                    <strong>{co.name}</strong>
                    <span>{co.tagline}</span>
                  </a>
                );
              })}
            </div>
            <a class="sub__feat" href={route('compare', lang)}>
              <strong>{c.compare.title}</strong>
              <span>{c.countriesIndex.compareCta} →</span>
            </a>
          </div>
        </li>

        <li class="has-sub">
          <button type="button" class="sub__btn" aria-expanded="false">{ui[lang].nav.services}</button>
          <div class="sub sub--services">
            <div class="sub__cols">
              {SERVICE_FAMILIES.map((f) => (
                <div class="sub__col">
                  <p class="sub__ttl">{c.common.serviceFamilies[f.key].name}</p>
                  <ul>
                    {f.services.map((s) => (
                      <li><a href={route(s, lang)}>{c.services[s].nav}</a></li>
                    ))}
                  </ul>
                </div>
              ))}
            </div>
            <a class="sub__feat" href={route('services', lang)}>
              <strong>{ui[lang].seeAllServices}</strong>
              <span>{ui[lang].familiesTagline}</span>
            </a>
          </div>
        </li>

        <li><a href={route('method', lang)} aria-current={isActive(route('method', lang)) ? 'page' : undefined}>{ui[lang].nav.method}</a></li>
        <li><a href={route('blog', lang)} aria-current={isActive(route('blog', lang)) ? 'page' : undefined}>{ui[lang].nav.insights}</a></li>
        <li><a href={route('about', lang)} aria-current={isActive(route('about', lang)) ? 'page' : undefined}>{ui[lang].nav.about}</a></li>
        <li><a href={route('contact', lang)} aria-current={isActive(route('contact', lang)) ? 'page' : undefined}>{ui[lang].nav.contact}</a></li>

        {LANGS.length > 1 && <li class="nav__lang"><LangSwitcher lang={lang} alternates={alternates} /></li>}
        <li class="nav__cta"><a class="btn btn--gold btn--sm" href={route('diagnostic', lang)}>{ui[lang].nav.diagnostic}</a></li>
      </ul>
    </nav>
  </div>
</header>

<style>
  .hd { position: sticky; top: 0; z-index: 100; background: rgba(255,255,255,.94); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px); border-bottom: 1px solid var(--line); }
  .hd__in { display: flex; align-items: center; justify-content: space-between; gap: 1rem; padding-block: .65rem; }
  .logo { display: inline-flex; align-items: center; gap: .6rem; text-decoration: none; }
  .logo__txt { display: grid; line-height: 1.12; }
  .logo__txt strong { font-family: var(--serif); font-weight: 700; font-size: 1.18rem; color: var(--ink); }
  .logo__txt em { font-style: normal; font-size: .62rem; font-weight: 600; letter-spacing: .3em; text-transform: uppercase; color: var(--gold); }

  .nav__list { list-style: none; display: flex; align-items: center; gap: clamp(.6rem, 1.6vw, 1.5rem); margin: 0; padding: 0; }
  .nav__list > li > a:not(.btn), .sub__btn {
    display: inline-block; text-decoration: none; font: inherit; font-size: .9rem; font-weight: 500;
    color: var(--text); background: none; border: 0; border-bottom: 2px solid transparent; padding: .35rem 0; cursor: pointer;
  }
  .nav__list > li > a:not(.btn):hover, .sub__btn:hover, .nav__list a[aria-current='page'] { color: var(--ink); border-bottom-color: var(--gold); }

  .has-sub { position: relative; }
  .sub {
    position: absolute; top: calc(100% + .65rem); left: 50%; transform: translateX(-50%) translateY(-6px);
    background: var(--white); border: 1px solid var(--line); border-radius: var(--radius);
    box-shadow: var(--shadow); padding: 1.2rem; opacity: 0; visibility: hidden; transition: .18s ease;
  }
  .has-sub:hover .sub, .has-sub:focus-within .sub, .sub.is-open { opacity: 1; visibility: visible; transform: translateX(-50%) translateY(0); }
  .sub--countries { width: min(560px, 92vw); }
  .sub--services { width: min(760px, 94vw); }
  .sub__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: .7rem; }
  .sub__card { display: grid; gap: .2rem; padding: .8rem; border-radius: var(--radius-sm); text-decoration: none; border: 1px solid var(--line); transition: .16s ease; }
  .sub__card:hover { border-color: rgba(211,172,43,.6); background: var(--mist); }
  .sub__card strong { font-family: var(--serif); font-size: 1.15rem; color: var(--ink); }
  .sub__card span { font-size: .78rem; color: var(--muted); }
  .sub__cols { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.4rem; }
  .sub__ttl { font-size: .7rem; font-weight: 600; letter-spacing: .16em; text-transform: uppercase; color: var(--gold); margin-bottom: .5rem; }
  .sub__cols ul { list-style: none; padding: 0; display: grid; gap: .38rem; }
  .sub__cols a { font-size: .87rem; color: var(--text); text-decoration: none; }
  .sub__cols a:hover { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }
  .sub__feat { display: grid; gap: .12rem; margin-top: 1rem; padding: .8rem 1rem; border-radius: var(--radius-sm); background: var(--mist); text-decoration: none; }
  .sub__feat strong { font-size: .9rem; color: var(--ink); }
  .sub__feat span { font-size: .78rem; color: var(--amethyst); }

  .nav__tgl { display: none; background: none; border: 0; padding: .5rem; flex-direction: column; gap: 5px; }
  .nav__tgl span { display: block; width: 24px; height: 2px; background: var(--ink); border-radius: 2px; transition: .2s ease; }

  @media (max-width: 1080px) {
    .nav__tgl { display: flex; }
    .nav__list {
      position: absolute; top: 100%; left: 0; right: 0; flex-direction: column; align-items: stretch; gap: 0;
      background: var(--white); border-bottom: 1px solid var(--line); box-shadow: var(--shadow-soft);
      padding: .5rem var(--gutter) 1.2rem; display: none; max-height: 80vh; overflow-y: auto;
    }
    .nav__list.is-open { display: flex; }
    .nav__list > li { padding-block: .25rem; }
    .nav__list > li > a:not(.btn), .sub__btn { display: block; width: 100%; text-align: left; font-size: 1rem; padding-block: .55rem; }
    .sub { position: static; transform: none; opacity: 1; visibility: visible; width: auto; box-shadow: none; border: 0; padding: .2rem 0 .6rem .8rem; display: none; }
    .sub.is-open { display: block; }
    .has-sub:hover .sub { display: none; }
    .has-sub:hover .sub.is-open { display: block; }
    .sub__grid, .sub__cols { grid-template-columns: 1fr; gap: .5rem; }
    .nav__cta { margin-top: .5rem; }
    .nav__tgl[aria-expanded='true'] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
    .nav__tgl[aria-expanded='true'] span:nth-child(2) { opacity: 0; }
    .nav__tgl[aria-expanded='true'] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  }
</style>

<script is:inline>
  (function () {
    var tgl = document.querySelector('.nav__tgl');
    var list = document.getElementById('nav-list');
    if (tgl && list) {
      tgl.addEventListener('click', function () {
        var open = tgl.getAttribute('aria-expanded') === 'true';
        tgl.setAttribute('aria-expanded', String(!open));
        list.classList.toggle('is-open', !open);
      });
    }
    document.querySelectorAll('.sub__btn').forEach(function (btn) {
      btn.addEventListener('click', function (e) {
        if (window.innerWidth > 1080) return;
        e.preventDefault();
        var sub = btn.parentElement.querySelector('.sub');
        var open = btn.getAttribute('aria-expanded') === 'true';
        btn.setAttribute('aria-expanded', String(!open));
        if (sub) sub.classList.toggle('is-open', !open);
      });
    });
  })();
</script>
