---
import { waLink, type Lang } from '../config/site';
import { ui } from '../i18n/ui';

interface Props {
  lang: Lang;
  title: string;
  text: string;
  note?: string;
  waContext?: string;
}
const { lang, title, text, note, waContext = 'plan' } = Astro.props;
const t = ui[lang];
---

<section class="section section--ink cta-final">
  <div class="container center">
    <h2 class="reveal">{title}</h2>
    <p class="lede reveal">{text}</p>
    <p class="mt-3 reveal">
      <a class="btn btn--gold" href={waLink(lang, waContext)} rel="noopener" target="_blank">
        <svg class="icon" viewBox="0 0 24 24" aria-hidden="true" fill="currentColor"><path d="M12.04 2a9.9 9.9 0 0 0-8.5 14.94L2 22l5.2-1.5A9.9 9.9 0 1 0 12.04 2Zm0 1.67a8.23 8.23 0 1 1-4.2 15.31l-.3-.18-3.08.89.84-3-.2-.31a8.23 8.23 0 0 1 6.94-12.71Zm-3.3 4.36c-.18 0-.47.07-.72.34-.24.27-.94.92-.94 2.24 0 1.32.96 2.6 1.1 2.78.13.18 1.87 2.99 4.62 4.07 2.28.9 2.75.72 3.24.68.5-.05 1.6-.65 1.82-1.28.23-.63.23-1.17.16-1.28-.07-.12-.25-.18-.52-.32s-1.6-.79-1.85-.88c-.25-.09-.43-.13-.61.14-.18.27-.7.88-.86 1.06-.16.18-.32.2-.59.07a7.42 7.42 0 0 1-2.18-1.35 8.2 8.2 0 0 1-1.51-1.88c-.16-.27-.02-.42.12-.55.12-.12.27-.32.4-.48.14-.16.18-.27.27-.45.09-.18.05-.34-.02-.48-.07-.13-.6-1.46-.83-2-.2-.46-.4-.4-.55-.4l-.55-.03Z" /></svg>
        {t.cta.whatsapp}
      </a>
      {note && <span class="btn-note">{note}</span>}
    </p>
  </div>
</section>

<style>
  .cta-final .lede {
    margin-inline: auto;
  }
</style>
