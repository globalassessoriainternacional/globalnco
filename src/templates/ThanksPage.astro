---
import Base from '../layouts/Base.astro';
import { type Lang } from '../config/site';
import { ui } from '../i18n/ui';
import { route, alternatesFor } from '../i18n/routes';
import { content } from '../data';
import { getPostsByLang, postUrl } from '../lib/blog';
interface Props { lang: Lang }
const { lang } = Astro.props; const c = content[lang]; const t = c.thanks;
const posts = (await getPostsByLang(lang)).slice(0, 3);
---
<Base lang={lang} title={t.metaTitle} description={t.text} path={route('thanks', lang)} alternates={alternatesFor('thanks')} noindex={true}>
  <section class="section center thx">
    <div class="container">
      <svg viewBox="0 0 48 48" width="56" height="56" aria-hidden="true" class="thx__ic"><circle cx="24" cy="24" r="22" fill="none" stroke="var(--gold)" stroke-width="2"/><path d="M15 24.5 21.5 31 34 18" fill="none" stroke="var(--gold)" stroke-width="2.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
      <h1 class="mt-2">{t.title}</h1>
      <p class="lede" style="margin-inline:auto">{t.text}</p>
      <p class="thx__next">{t.next}</p>
      <p class="mt-3"><a class="btn btn--ghost" href={route('home', lang)}>{t.back}</a></p>
    </div>
  </section>
  {posts.length > 0 && (
    <section class="section section--mist">
      <div class="container">
        <div class="section-head center"><h2>{ui[lang].meanwhile}</h2></div>
        <div class="grid grid--3">
          {posts.map((p) => (<a class="card" href={postUrl(p)}><p class="card__title">{p.data.title}</p><p class="card__text">{p.data.description}</p></a>))}
        </div>
      </div>
    </section>
  )}
</Base>
<style>
  .thx { padding-block: clamp(4rem, 10vw, 7rem); }
  .thx__ic { display: block; margin-inline: auto; }
  .thx__next { margin-top: 1.2rem; font-size: .92rem; color: var(--muted); max-width: 60ch; margin-inline: auto; }
</style>
