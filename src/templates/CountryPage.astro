---
import Base from '../layouts/Base.astro';
import Hero from '../components/Hero.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import FaqList from '../components/FaqList.astro';
import ServiceGrid from '../components/ServiceGrid.astro';
import LeadForm from '../components/LeadForm.astro';
import { absoluteUrl, SITE_URL, waLink, type Lang } from '../config/site';
import { route, alternatesFor, type PageKey } from '../i18n/routes';
import { content } from '../data';

interface Props { lang: Lang; countryKey: PageKey }
const { lang, countryKey } = Astro.props;
const c = content[lang];
const key = countryKey.replace('country:', '');
const co = c.countries[key];
const path = route(countryKey, lang);
const img = `/img/pais-${key}.jpg`;

const schema = [
  { '@type': 'WebPage', '@id': absoluteUrl(path) + '#webpage', url: absoluteUrl(path), name: co.metaTitle, description: co.metaDescription, about: { '@id': `${SITE_URL}/#organization` } },
  { '@type': 'FAQPage', mainEntity: co.faqs.map((f) => ({ '@type': 'Question', name: f.q, acceptedAnswer: { '@type': 'Answer', text: f.a } })) },
];
---
<Base lang={lang} title={co.metaTitle} description={co.metaDescription} path={path} alternates={alternatesFor(countryKey)} ogImage={img} schema={schema}>
  <Hero eyebrow="Onde atuamos" title={co.name} accent={co.tagline} lede={co.lede} image={img} compact={false}>
    <a class="btn btn--gold" href={route('diagnostic', lang)}>Solicitar diagnóstico</a>
    <a class="btn btn--ghost-light" href={waLink(lang, key)} rel="noopener" target="_blank">Falar sobre {co.name}</a>
  </Hero>

  <div class="container bc-wrap"><Breadcrumbs lang={lang} items={[{ label: c.countriesIndex.breadcrumb, href: route('countries', lang) }, { label: co.name }]} /></div>

  <section class="section">
    <div class="container">
      <div class="grid grid--2">
        {co.highlights.map((h) => (<div class="card reveal"><p class="card__title">{h.t}</p><p class="card__text">{h.d}</p></div>))}
      </div>
    </div>
  </section>

  <section class="section section--ink">
    <div class="container">
      <div class="section-head reveal"><p class="eyebrow eyebrow--light">Indicadores</p><h2>O que os dados mostram</h2></div>
      <div class="ind">
        {co.indicators.map((i) => (
          <div class="ind__i reveal"><strong>{i.value}</strong><span>{i.label}</span><em>{i.source}</em></div>
        ))}
      </div>
    </div>
  </section>

  <section class="section section--mist">
    <div class="container split2">
      <div class="reveal">
        <h2 class="h-sub">{co.forWho.title}</h2>
        <ul class="check-list mt-2">{co.forWho.items.map((i) => <li>{i}</li>)}</ul>
      </div>
      <div class="reveal reality">
        <h2 class="h-sub">{co.reality.title}</h2>
        <p class="card__text mt-1">{co.reality.text}</p>
        <ul class="x-list mt-2">{co.reality.items.map((i) => <li>{i}</li>)}</ul>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head reveal"><h2>{co.services.title}</h2><p class="lede">{co.services.text}</p></div>
      <ServiceGrid lang={lang} />
    </div>
  </section>

  <section class="section section--mist">
    <div class="container faq-wrap">
      <h2 class="center">Perguntas frequentes sobre o {co.name}</h2>
      <div class="mt-3"><FaqList items={co.faqs} /></div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="section-head reveal"><h2>{co.cta.title}</h2><p class="lede">{co.cta.text}</p></div>
      <div class="lead-wrap"><LeadForm lang={lang} presetCountry={key} /></div>
      <p class="mt-3 reveal"><a class="btn btn--ghost btn--sm" href={route('compare', lang)}>Comparar com os outros países →</a></p>
    </div>
  </section>
</Base>

<style>
  .bc-wrap { padding-top: 1.2rem; }
  .split2 { display: grid; gap: 2.4rem; }
  @media (min-width: 880px) { .split2 { grid-template-columns: 1fr 1fr; } }
  .h-sub { font-size: clamp(1.4rem, 1.1rem + 1.2vw, 1.9rem); }
  .ind { display: grid; gap: 1.4rem; }
  @media (min-width: 760px) { .ind { grid-template-columns: repeat(4, 1fr); } }
  .ind__i { display: grid; gap: .25rem; border-left: 2px solid var(--gold); padding-left: 1rem; }
  .ind__i strong { font-family: var(--serif); font-size: 1.35rem; color: var(--gold); }
  .ind__i span { font-size: .88rem; color: rgba(255,255,255,.82); }
  .ind__i em { font-style: normal; font-size: .74rem; color: rgba(255,255,255,.5); }
  .x-list { list-style: none; padding: 0; display: grid; gap: .7rem; }
  .x-list li { position: relative; padding-left: 1.9rem; color: var(--muted); }
  .x-list li::before { content: '×'; position: absolute; left: .35rem; top: -.05em; font-size: 1.25rem; color: #9b2c2c; font-weight: 700; }
  .faq-wrap { max-width: 860px; }
  .lead-wrap { max-width: 720px; }
</style>
