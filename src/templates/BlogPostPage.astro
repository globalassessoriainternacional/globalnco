---
import Base from '../layouts/Base.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { absoluteUrl, SITE_URL, waLink, type Lang } from '../config/site';
import { ui } from '../i18n/ui';
import { route } from '../i18n/routes';
import { content } from '../data';
import { render } from 'astro:content';
import { postUrl, postLang, getTranslations, readingTime, getPostsByLang, type Post } from '../lib/blog';

interface Props { post: Post }
const { post } = Astro.props;
const lang = postLang(post) as Lang;
const c = content[lang]; const b = c.blog;
const { Content, headings } = await render(post);
const url = postUrl(post);
const alternates = await getTranslations(post);
const rt = readingTime(post.body);
const fmt = new Intl.DateTimeFormat('pt-BR', { day: '2-digit', month: 'long', year: 'numeric' });
const all = await getPostsByLang(lang);
const related = all.filter((p) => p.id !== post.id && p.data.category === post.data.category).slice(0, 3);
const fallback = all.filter((p) => p.id !== post.id).slice(0, 3);
const rel = related.length ? related : fallback;
const toc = headings.filter((h) => h.depth === 2);

const schema = [
  {
    '@type': 'BlogPosting', '@id': absoluteUrl(url) + '#post', headline: post.data.title,
    description: post.data.description, url: absoluteUrl(url), inLanguage: lang,
    datePublished: post.data.pubDate.toISOString(),
    dateModified: (post.data.updatedDate ?? post.data.pubDate).toISOString(),
    articleSection: post.data.category, keywords: (post.data.tags || []).join(', '),
    wordCount: post.body ? post.body.trim().split(/\s+/).length : undefined,
    author: { '@id': `${SITE_URL}/#organization` },
    publisher: { '@id': `${SITE_URL}/#organization` },
    mainEntityOfPage: { '@type': 'WebPage', '@id': absoluteUrl(url) },
    image: absoluteUrl(post.data.image || '/img/og-default.jpg'),
  },
];
---
<Base lang={lang} title={post.data.title.length > 50 ? post.data.title : post.data.title + ' | Global & Co.'} description={post.data.description} path={url}
      alternates={alternates} ogImage={post.data.image || '/img/og-default.jpg'} ogType="article" schema={schema}>
  <article class="section section--tight">
    <div class="container art">
      <Breadcrumbs lang={lang} items={[{ label: b.breadcrumb, href: route('blog', lang) }, { label: post.data.title }]} />
      <header class="art__hd">
        <p class="art__meta">{post.data.category} · {fmt.format(post.data.pubDate)} · {rt} {b.readingTime}</p>
        <h1>{post.data.title}</h1>
        <p class="lede">{post.data.description}</p>
      </header>

      <div class="art__body">
        {toc.length > 2 && (
          <nav class="toc" aria-label="Sumário">
            <p class="toc__t">{ui[lang].inThisArticle}</p>
            <ul>{toc.map((h) => (<li><a href={'#' + h.slug}>{h.text}</a></li>))}</ul>
          </nav>
        )}
        <div class="prose"><Content /></div>
      </div>

      {post.data.tags && post.data.tags.length > 0 && (
        <p class="art__tags">{post.data.tags.map((t) => <span class="tag">{t}</span>)}</p>
      )}

      <aside class="art__cta">
        <p class="art__ctat">{ui[lang].postCtaTitle}</p>
        <p class="art__ctad">{ui[lang].postCtaText}</p>
        <p class="art__ctab">
          <a class="btn btn--gold" href={route('diagnostic', lang)}>{ui[lang].diagnostic}</a>
          <a class="btn btn--ghost" href={waLink(lang)} rel="noopener" target="_blank">{ui[lang].whatsapp}</a>
        </p>
      </aside>
    </div>
  </article>

  {rel.length > 0 && (
    <section class="section section--mist">
      <div class="container">
        <div class="section-head"><h2>{b.related}</h2></div>
        <div class="grid grid--3">
          {rel.map((p) => (<a class="card" href={postUrl(p)}><p class="card__num">{p.data.category}</p><p class="card__title">{p.data.title}</p><p class="card__text">{p.data.description}</p></a>))}
        </div>
        <p class="mt-3 center"><a class="btn btn--ghost btn--sm" href={route('blog', lang)}>{b.all}</a></p>
      </div>
    </section>
  )}
</Base>
<style>
  .art { max-width: 820px; }
  .art__hd { margin: 1.4rem 0 2rem; }
  .art__meta { font-size: .74rem; letter-spacing: .12em; text-transform: uppercase; color: var(--gold); font-weight: 600; margin-bottom: .6rem; }
  .toc { margin-bottom: 2rem; padding: 1.1rem 1.3rem; background: var(--mist); border-left: 3px solid var(--gold); border-radius: var(--radius-sm); }
  .toc__t { font-size: .72rem; font-weight: 700; letter-spacing: .14em; text-transform: uppercase; color: var(--muted); margin-bottom: .6rem; }
  .toc ul { list-style: none; padding: 0; display: grid; gap: .38rem; }
  .toc a { font-size: .89rem; color: var(--indigo); text-decoration: none; }
  .toc a:hover { text-decoration: underline; }
  .prose :global(h2) { font-size: clamp(1.4rem, 1.1rem + 1.3vw, 1.95rem); margin: 2.4rem 0 .9rem; scroll-margin-top: 90px; }
  .prose :global(h3) { font-size: 1.22rem; margin: 1.8rem 0 .6rem; color: var(--indigo); }
  .prose :global(p) { margin-bottom: 1.15rem; font-size: 1.04rem; line-height: 1.78; }
  .prose :global(ul), .prose :global(ol) { margin: 0 0 1.3rem 1.3rem; display: grid; gap: .5rem; }
  .prose :global(li) { line-height: 1.7; }
  .prose :global(strong) { color: var(--ink); }
  .prose :global(a) { color: var(--indigo); text-underline-offset: 3px; }
  .prose :global(blockquote) { margin: 1.8rem 0; padding: .4rem 0 .4rem 1.4rem; border-left: 3px solid var(--gold); font-family: var(--serif); font-size: 1.25rem; font-style: italic; color: var(--indigo); }
  .prose :global(table) { width: 100%; border-collapse: collapse; margin: 1.6rem 0; font-size: .92rem; }
  .prose :global(th), .prose :global(td) { padding: .7rem .9rem; border: 1px solid var(--line); text-align: left; }
  .prose :global(th) { background: var(--mist); color: var(--ink); }
  .prose :global(hr) { border: 0; border-top: 1px solid var(--line); margin: 2.4rem 0; }
  .art__tags { margin-top: 2rem; display: flex; gap: .45rem; flex-wrap: wrap; }
  .tag { font-size: .74rem; padding: .28rem .7rem; border-radius: 999px; background: var(--mist); color: var(--muted); border: 1px solid var(--line); }
  .art__cta { margin-top: 2.6rem; padding: 1.6rem 1.8rem; border: 1px solid rgba(211,172,43,.4); border-radius: var(--radius); background: var(--mist); }
  .art__ctat { font-family: var(--serif); font-size: 1.3rem; color: var(--ink); }
  .art__ctad { font-size: .92rem; color: var(--muted); margin: .6rem 0 1.1rem; }
  .art__ctab { display: flex; gap: .7rem; flex-wrap: wrap; }
</style>
