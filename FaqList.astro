---
import { route, COUNTRY_KEYS } from '../i18n/routes';
import { content } from '../data';
import type { Lang } from '../config/site';
interface Props { lang: Lang }
const { lang } = Astro.props;
const c = content[lang];
const imgs: Record<string,string> = { uruguai: '/img/pais-uruguai.jpg', chile: '/img/pais-chile.jpg', paraguai: '/img/pais-paraguai.jpg' };
---
<div class="cc">
  {COUNTRY_KEYS.map((k) => {
    const key = k.replace('country:', '');
    const co = c.countries[key];
    return (
      <a class="cc__card reveal" href={route(k, lang)} style={`--img:url('${imgs[key]}')`}>
        <div class="cc__media" role="presentation"></div>
        <div class="cc__body">
          <h3 class="cc__name">{co.name}</h3>
          <p class="cc__tag">{co.tagline}</p>
          <p class="cc__more">Ver o que estruturamos →</p>
        </div>
      </a>
    );
  })}
</div>
<style>
  .cc { display: grid; gap: 1.2rem; }
  @media (min-width: 760px) { .cc { grid-template-columns: repeat(3, 1fr); } }
  .cc__card { display: grid; grid-template-rows: auto 1fr; text-decoration: none; color: inherit;
    border: 1px solid var(--line); border-radius: var(--radius); overflow: hidden; background: var(--white);
    transition: transform .22s ease, box-shadow .22s ease, border-color .22s ease; }
  .cc__card:hover { transform: translateY(-4px); box-shadow: var(--shadow-soft); border-color: rgba(211,172,43,.55); }
  .cc__media { height: 150px; background-image: linear-gradient(180deg, rgba(24,16,71,.15), rgba(24,16,71,.55)), var(--img); background-size: cover; background-position: center; }
  .cc__body { padding: 1.2rem 1.3rem 1.4rem; display: grid; gap: .4rem; align-content: start; }
  .cc__name { font-family: var(--serif); font-size: 1.6rem; color: var(--ink); }
  .cc__tag { font-size: .9rem; color: var(--muted); }
  .cc__more { margin-top: .4rem; font-size: .84rem; font-weight: 600; color: var(--indigo); }
  .cc__card:hover .cc__more { color: var(--ink); }
</style>
